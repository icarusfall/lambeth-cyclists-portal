# --- Auth ---
# Long random string used to sign session cookies (e.g. `python -c "import secrets; print(secrets.token_urlsafe(48))"`)
SESSION_SECRET=change-me
# Comma-separated name:bcrypt-hash pairs. Generate entries with `python scripts/hash_password.py`
PORTAL_USERS=charlie:$2b$12$examplehash,colin:$2b$12$examplehash

# --- Notion ---
# Integration token with READ + WRITE access, connected to the Meetings/Items/Projects
# databases and to the Newsletters database (see scripts/create_newsletters_db.py)
NOTION_API_TOKEN=
# Database IDs (defaults are the live Lambeth Cyclists databases; override if they change)
NOTION_MEETINGS_DB=2e42d7a24378803fb811d2f6ed029137
NOTION_ITEMS_DB=2e32d7a2437880298c81f1af94c441a0
NOTION_PROJECTS_DB=2e42d7a2437880d686e8ff554556b0c1
# Created by scripts/create_newsletters_db.py — paste the printed ID here
NOTION_NEWSLETTERS_DB=

# --- AI (on-demand only: suggest stories, news scan, draft newsletter) ---
ANTHROPIC_API_KEY=

# --- Sending ---
RESEND_API_KEY=
NEWSLETTER_FROM=Lambeth Cyclists <newsletter@lambethcyclists.com>
# The Google Group address the newsletter is emailed to
GROUP_EMAIL=
